# Copy this file to .env and fill in your values.
# All three variables are required — the app will log an error and may
# behave incorrectly if any are missing.

# Your Supabase project URL (found in Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key (found in Project Settings → API)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# The base URL of the Cloudflare Workers API
# Local dev: http://localhost:8787
# Production: https://api.bhuiyanworkforce.com
VITE_API_URL=https://api.bhuiyanworkforce.com
